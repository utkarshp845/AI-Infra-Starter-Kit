# Day 1 works with no LLM key. Set LLM_PROVIDER=none to use the deterministic analyzer.
LLM_PROVIDER=none

# OpenAI-compatible provider settings. These can point to OpenAI, Ollama, or another compatible API.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# Docker Compose mounts ./logs to /shared/logs in both app containers.
DEMO_SERVICE_LOG_PATH=/shared/logs/demo-service.log

